{
  "name": "azure-entra-enterprise-app-action",
  "version": "1.0.0",
  "description": "Custom GitHub Action for creating Azure Entra ID enterprise applications",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.js --source-map --license licenses.txt",
    "package": "npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write src/**/*.js",
    "validate": "npm run lint && npm run test",
    "pre-commit": "npm run format && npm run lint && npm run test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/krishnavatsavai/azure-entra-enterprise-app-automation.git"
  },
  "keywords": [
    "github-action",
    "azure",
    "entra-id",
    "enterprise-applications",
    "automation",
    "sso",
    "saml"
  ],
  "author": "DevOps Team",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@azure/msal-node": "^2.6.6",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "axios": "^1.6.7",
    "yaml": "^2.3.4",
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "winston": "^3.11.0",
    "date-fns": "^3.3.1"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-node": "^11.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/",
    "action.yml",
    "README.md"
  ]
}